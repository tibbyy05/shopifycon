# ── Supabase Edge Function secrets ──────────────────────────────────
# Set these with:  supabase secrets set --env-file .env
# (SUPABASE_URL / SUPABASE_SERVICE_ROLE_KEY / SUPABASE_ANON_KEY are injected
#  automatically into Edge Functions — do not set them here.)

# Shopify app credentials (Partner dashboard → App → API credentials)
SHOPIFY_API_KEY=
SHOPIFY_API_SECRET=

# Comma-separated OAuth scopes requested at install (read-only app)
SHOPIFY_SCOPES=read_orders,read_fulfillments,read_products,read_inventory

# 32 random bytes, base64 — encrypts Shopify tokens at rest (AES-256-GCM).
# Generate:  openssl rand -base64 32
TOKEN_ENCRYPTION_KEY=

# Random secret the cron job must present to invoke the rules sweep.
# Generate:  openssl rand -hex 32
SWEEP_SECRET=

# SendGrid (v1 alert channel)
SENDGRID_API_KEY=
ALERT_FROM_EMAIL=
# Fallback recipient when a shop has no alert_channels row yet
ALERT_DEFAULT_TO=

# Where the dashboard lives (OAuth flow redirects here when done)
DASHBOARD_URL=http://localhost:5173

# ── Frontend (web/.env) ─────────────────────────────────────────────
# VITE_SUPABASE_URL=
# VITE_SUPABASE_ANON_KEY=
